# Copy to .env.local (not committed).

# Backend origin for POST /api/v1/upload from the browser (direct; enable CORS on Go).
# In development, if unset, http://127.0.0.1:8080 is used.
# NEXT_PUBLIC_TMPVAULT_API_URL=http://127.0.0.1:8080

# Where Next.js proxies GET /download/* only.
# TMPVAULT_BACKEND_URL=http://127.0.0.1:8080
